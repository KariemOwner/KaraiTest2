# KarAI v2 Environment Variables Configuration
# Sarkas tapi Berguna
#
# IMPORTANT: This file should NOT be committed to version control.
# Copy this file to .env and fill in your actual values.
#
# For local development:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual credentials in .env
#   3. Use a local server that supports loading .env files
#      (e.g., Vite, Parcel, or a simple Node.js server with dotenv)
#
# For Vercel deployment:
#   1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
#   2. Add each variable listed below
#   3. Deploy again for changes to take effect

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: Never expose the service_role key in frontend code!
# This is only for server-side functions (Vercel API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Set up Google OAuth in Supabase dashboard:
# Authentication → Providers → Google

GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ============================================
# AI API KEYS (Server-side only - Vercel Functions)
# ============================================
# These keys should NEVER be exposed in frontend code.
# They are only used in /api/* serverless functions.

GROQ_API_KEY=your-groq-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ============================================
# OPTIONAL: OTHER CONFIGURATION
# ============================================

# Application URL (for OAuth redirects)
APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
